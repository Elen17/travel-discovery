# API base URL (includes /api/v1 prefix)
VITE_API_BASE_URL=https://travel-discovery-backend-production.up.railway.app/api/v1

# Local development (uncomment to use local backend)
# VITE_API_BASE_URL=http://localhost:8080/api/v1

VITE_GOOGLE_CLIENT_ID=

VITE_MAPTILER_API_KEY=your_default_key_here

# Planner mock fallback — uses built-in demo assistant only when the backend is unavailable
# Set to false to disable fallback and surface API errors instead
# VITE_PLANNER_USE_MOCK=true

# Google Gemini (optional — client-side planner when configured)
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=gemini-2.5-flash
# Omit VITE_GEMINI_API_URL (recommended) or set only the base:
# VITE_GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
# Do NOT include :generateContent or the model id in VITE_GEMINI_API_URL — that is appended automatically.


# Telegram admin notifications (optional — booking checkout, confirm, cancel)
# VITE_TELEGRAM_URL=https://api.telegram.org/bot
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=
VITE_TELEGRAM_API_BASE=